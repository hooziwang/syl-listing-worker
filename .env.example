# =========================
# syl-listing-worker 敏感配置示例
# 说明：
# 1) 本文件只放敏感信息，不放非敏感业务配置。
# 2) 非敏感配置统一放在 worker.config.json。
# 3) 复制为 .env 后，替换为真实值。
# =========================

# JWT 签名密钥：
# - 用于签发/校验 /v1/auth/exchange 返回的 access_token（JWT）
# - 修改后旧 token 会立即失效
# - 建议使用 32 位以上随机字符串
JWT_SECRET=replace_me_with_at_least_16_chars

# 租户访问密钥映射（客户端首登凭证）：
# - 格式：tenant_id:key,tenant2:key2
# - CLI 使用 Authorization: Bearer <SYL_LISTING_KEY> 调 /v1/auth/exchange
# - worker 根据这里的映射识别 tenant_id 并发放 JWT
# - 不支持多行；必须写成一行逗号分隔
SYL_LISTING_KEYS=demo:demo_key,syl:replace_with_real_syl_key

# 管理口令（仅管理接口使用）：
# - 用于 /v1/admin/tenant-rules/publish 与 /v1/admin/tenant-rules/rollback
# - 通过请求头 x-admin-token 传递
ADMIN_TOKEN=replace_admin_token

# 生成模型密钥（fluxcode）：
# - worker 用它调用生成模型（标题/五点/描述/搜索词）
FLUXCODE_API_KEY=replace_fluxcode_key

# 翻译模型密钥（deepseek）：
# - worker 用它执行英文到中文翻译
DEEPSEEK_API_KEY=replace_deepseek_key

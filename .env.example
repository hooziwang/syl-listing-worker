PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

REDIS_URL=redis://127.0.0.1:6379
QUEUE_NAME=syl_listing_jobs
WORKER_CONCURRENCY=10

JWT_SECRET=replace_me_with_at_least_16_chars
JWT_EXPIRES_SECONDS=900

# 格式: tenant_id:key,tenant2:key2
SYL_LISTING_KEYS=demo:demo_key

# 管理端口令（rules 发布使用）
ADMIN_TOKEN=replace_admin_token

# API 对外基地址（用于返回规则包下载地址）
API_PUBLIC_BASE_URL=http://127.0.0.1:8080

# 本地规则包存储
RULES_FS_DIR=/data/syl-listing/rules

# 冷启动引导规则（如无发布记录）
BOOTSTRAP_RULES_TENANT=demo
BOOTSTRAP_RULES_VERSION=tenant-demo-v1
BOOTSTRAP_RULES_MANIFEST_SHA256=demo_sha256
BOOTSTRAP_RULES_SIGNATURE_BASE64=
BOOTSTRAP_RULES_SIGNATURE_ALGO=ed25519

# 生成模型（fluxcode）
FLUXCODE_BASE_URL=https://flux-code.cc
FLUXCODE_RESPONSES_PATH=/v1/responses
FLUXCODE_API_KEY=replace_fluxcode_key
FLUXCODE_MODEL=gpt-5.3-codex
FLUXCODE_REASONING_EFFORT=high
FLUXCODE_TEMPERATURE=1.2

# 翻译模型（deepseek）
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_PATH=/chat/completions
DEEPSEEK_API_KEY=replace_deepseek_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TEMPERATURE=1.3

# 通用退避重试
RETRY_BASE_MS=400
RETRY_MAX_MS=8000
RETRY_JITTER=0.25

JOB_TTL_SECONDS=3600

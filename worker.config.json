{
  "server": {
    "domain": "worker.aelus.tech",
    "letsencrypt_email": "",
    "node_env": "production",
    "host": "0.0.0.0",
    "port": 8080,
    "log_level": "info",
    "api_public_base_url": "https://worker.aelus.tech"
  },
  "redis": {
    "url": "redis://redis:6379"
  },
  "queue": {
    "name": "syl_listing_jobs",
    "worker_concurrency": 10,
    "job_ttl_seconds": 3600
  },
  "auth": {
    "jwt_expires_seconds": 900
  },
  "rules": {
    "fs_dir": "/data/syl-listing/rules",
    "bootstrap": {
      "tenant": "demo",
      "version": "tenant-demo-v1",
      "manifest_sha256": "demo_sha256",
      "signature_base64": "",
      "signature_algo": "ed25519"
    }
  },
  "providers": {
    "deepseek": {
      "base_url": "https://api.deepseek.com",
      "chat_path": "/chat/completions",
      "model": "deepseek-chat",
      "temperature": 1.3
    }
  },
  "healthcheck": {
    "llm": {
      "cache_seconds": 300,
      "timeout_seconds": 12,
      "retries": 2
    }
  },
  "retry": {
    "base_ms": 400,
    "max_ms": 8000,
    "jitter": 0.25
  }
}
